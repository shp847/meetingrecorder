{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meeting-recorder.local/schemas/diarization-fixture-catalog.schema.json",
  "title": "Meeting Recorder Diarization Fixture Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fixtures"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "description": {
      "type": "string"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixture"
      }
    }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "mode",
        "enabled",
        "transcriptJsonPath",
        "expectedSpeakerCount",
        "expectedSpeakerNames",
        "expectedNameMode",
        "enableSpeakerNameMatching",
        "protectedArtifactPaths"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "two-speaker",
            "one-speaker",
            "three-plus-speaker",
            "short-call",
            "noisy-similar-voices"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "stored-turn",
            "full-audio"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "disabledReason": {
          "type": "string"
        },
        "manifestPath": {
          "type": "string"
        },
        "audioPath": {
          "type": "string"
        },
        "transcriptionSnapshotPath": {
          "type": "string"
        },
        "transcriptJsonPath": {
          "type": "string"
        },
        "transcriptMarkdownPath": {
          "type": "string"
        },
        "configPath": {
          "type": "string"
        },
        "speakerLabelingProfile": {
          "type": "string",
          "enum": [
            "Configured",
            "Standard",
            "HighAccuracy"
          ]
        },
        "diarizationAssetPath": {
          "type": "string"
        },
        "accelerationPreference": {
          "type": "string",
          "enum": [
            "CpuOnly",
            "Auto"
          ]
        },
        "expectedSpeakerCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "expectedSpeakerNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectedNameMode": {
          "type": "string",
          "enum": [
            "none",
            "assert"
          ]
        },
        "enableSpeakerNameMatching": {
          "type": "boolean"
        },
        "protectedArtifactPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "probeRoot": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
