                                    <StackPanel Grid.Row="13" Grid.ColumnSpan="3" Orientation="Horizontal">
                                        <CheckBox x:Name="ConfigLaunchOnLoginCheckBox" Margin="0,8,18,0" Content="Launch app when I sign in" />
                                        <TextBlock Margin="0,10,0,0" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately; takes effect on the next sign-in or machine restart" />
                                    </StackPanel>
                                    </Grid>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.ColumnSpan="3"
                                               FontWeight="SemiBold"
                                               Text="App Updates" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Margin="0,6,0,16"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Point the app at a shared release feed, such as the GitHub Releases API. Daily checks and idle auto-install behavior are controlled here, while the Updates tab shows the current release status and lets you trigger installs manually." />

                                    <CheckBox x:Name="ConfigUpdateCheckEnabledCheckBox"
                                              Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Margin="0,0,0,12"
                                              Content="Run automatic GitHub update checks every day while the app is open" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               Margin="12,0,0,12"
                                               VerticalAlignment="Center"
                                               Foreground="#45504D"
                                               Text="Applies immediately" />

                                    <CheckBox x:Name="ConfigAutoInstallUpdatesCheckBox"
                                              Grid.Row="3"
                                              Grid.ColumnSpan="2"
                                              Margin="0,0,0,12"
                                              Content="Automatically download and install updates when no recording or processing work is active" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="2"
                                               Margin="12,0,0,12"
                                               VerticalAlignment="Center"
                                               Foreground="#45504D"
                                               Text="Applies immediately" />

                                    <TextBlock x:Name="ConfigAutoInstallDependencyTextBlock"
                                               Grid.Row="4"
                                               Grid.ColumnSpan="3"
                                               Margin="0,0,0,12"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="5"
                                               Margin="0,0,12,12"
                                               VerticalAlignment="Center"
                                               Text="Update feed URL" />
                                    <TextBox x:Name="ConfigUpdateFeedUrlTextBox"
                                             Grid.Row="5"
                                             Grid.Column="1"
                                             Margin="0,0,0,12"
                                             Height="32"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="5"
                                               Grid.Column="2"
                                               Margin="12,0,0,12"
                                               VerticalAlignment="Center"
                                               Foreground="#45504D"
                                               Text="Next check" />
                                </Grid>
                            </Border>

                            <StackPanel Margin="0,16,0,0"
                                        Orientation="Horizontal">
                                <Button x:Name="SaveConfigButton"
                                        Width="140"
                                        Height="34"
                                        Click="SaveConfigButton_OnClick"
                                        Content="Save Config" />
                                <TextBlock x:Name="ConfigSaveStatusTextBlock"
                                           Margin="16,8,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="About">
                    <ScrollViewer Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="20"
                                               Text="{x:Static branding:AppBranding.DisplayNameWithVersion}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Local-first meeting recording and transcription for Teams, Google Meet, Zoom, Webex, and other conferencing apps, with portable deployment and automation-ready outputs." />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Margin="0,0,12,12"
                                               FontWeight="SemiBold"
                                               Text="Author" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="0,0,0,12"
                                               Foreground="#45504D"
                                               Text="{x:Static branding:AppBranding.AuthorName}" />

                                    <TextBlock Grid.Row="1"
                                               Margin="0,0,12,12"
                                               FontWeight="SemiBold"
                                               Text="Email" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="0,0,0,12"
                                               Foreground="#45504D"
                                               Text="{x:Static branding:AppBranding.AuthorEmail}" />

                                    <TextBlock Grid.Row="2"
                                               Margin="0,0,12,0"
                                               FontWeight="SemiBold"
                                               Text="Release page" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Foreground="#45504D"
                                               Text="{x:Static branding:AppBranding.DefaultReleasePageUrl}" />
                                </Grid>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Support" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="If something looks wrong, the fastest troubleshooting path is usually the Models tab for Whisper setup and the app log under the data\logs folder." />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Legal notice" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="{x:Static branding:AppBranding.RecordingLegalNotice}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
