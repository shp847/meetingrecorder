                                                   Grid.ColumnSpan="2"
                                                   FontWeight="SemiBold"
                                                   Text="Automatic Behavior" />
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,8,12,0"
                                                   VerticalAlignment="Center"
                                                   Text="Schedule" />
                                        <TextBlock x:Name="UpdateAutomationSummaryTextBlock"
                                                   Grid.Row="1"
                                                   Grid.Column="1"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource ConfigSectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Manual Update Controls" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}"
                                                   Text="Use these controls anytime to check GitHub for a newer version and install it when the app is idle." />
                                        <WrapPanel Margin="0,16,0,0">
                                            <Button x:Name="CheckForUpdatesButton"
                                                    Width="170"
                                                    Height="34"
                                                    Margin="0,0,12,12"
                                                    Click="CheckForUpdatesButton_OnClick"
                                                    Content="Check for Updates" />
                                            <Button x:Name="InstallLatestUpdateButton"
                                                    Width="190"
                                                    Height="34"
                                                    Margin="0,0,12,12"
                                                    Click="InstallLatestUpdateButton_OnClick"
                                                    Content="Install Available Update" />
                                            <Button x:Name="DownloadLatestUpdateButton"
                                                    Width="170"
                                                    Height="34"
                                                    Margin="0,0,12,12"
                                                    Click="DownloadLatestUpdateButton_OnClick"
                                                    Content="Download Latest ZIP" />
                                            <Button x:Name="OpenLatestReleasePageButton"
                                                    Width="160"
                                                    Height="34"
                                                    Margin="0,0,0,12"
                                                    Click="OpenLatestReleasePageButton_OnClick"
                                                    Content="Open Release Page" />
                                        </WrapPanel>
                                        <ProgressBar x:Name="UpdateOperationProgressBar"
                                                     Margin="0,16,0,0"
                                                     Height="6"
                                                     IsIndeterminate="True"
                                                     Visibility="Collapsed" />
                                        <TextBlock x:Name="UpdateInstallAvailabilityTextBlock"
                                                   Margin="0,12,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}" />
                                        <TextBlock x:Name="LastUpdateCheckTextBlock"
                                                   Margin="0,16,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}" />
                                        <TextBlock x:Name="UpdateCheckStatusTextBlock"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                        <ScrollViewer x:Name="SettingsAdvancedSectionPanel"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <StackPanel>
                                <Border Style="{StaticResource ConfigSectionBorderStyle}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   FontSize="18"
                                                   Foreground="{StaticResource AppTextBrush}"
                                                   Text="Advanced &amp; Troubleshooting" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource ConfigHelpTextStyle}"
                                                   Text="Change these only when you need to relocate working folders, change technical runtime behavior, or inspect the managed storage paths the app is using." />
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Work folder" />
                                            <TextBox x:Name="ConfigWorkDirTextBox"
                                                     Margin="0,6,0,0"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="New work manifests, raw chunks, and processing logs are created here." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Model storage root" />
                                            <TextBlock x:Name="ConfigModelStorageSummaryTextBlock"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource ConfigHelpTextStyle}" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="Managed transcription and speaker-labeling files are stored here." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Transcription storage" />
                                            <TextBlock x:Name="ConfigTranscriptionStorageTextBlock"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource ConfigHelpTextStyle}" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="The active transcription profile is managed from Settings &gt; Setup." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Speaker labeling storage" />
                                            <TextBlock x:Name="ConfigSpeakerLabelingStorageTextBlock"
                                                       Margin="0,6,0,0"
                                                       Style="{StaticResource ConfigHelpTextStyle}" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="The active speaker-labeling profile is managed from Settings &gt; Setup." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Update feed URL" />
                                            <TextBox x:Name="ConfigUpdateFeedUrlTextBox"
                                                     Margin="0,6,0,0"
                                                     Height="32"
                                                     VerticalContentAlignment="Center" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="Point this at the shared release feed the app should use for update discovery." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Background processing mode" />
                                            <ComboBox x:Name="ConfigBackgroundProcessingModeComboBox"
                                                      Margin="0,6,0,0"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="Responsive pauses new backlog work during live recordings and keeps the worker below normal priority by default." />
                                        </StackPanel>
                                        <StackPanel Margin="0,14,0,0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Speaker labeling mode" />
                                            <ComboBox x:Name="ConfigBackgroundSpeakerLabelingModeComboBox"
                                                      Margin="0,6,0,0"
                                                      Height="32"
                                                      VerticalContentAlignment="Center" />
                                            <TextBlock Style="{StaticResource ConfigHelpTextStyle}"
                                                       Text="Deferred publishes audio and transcripts first, then leaves speaker labels for manual follow-up later." />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>


            </Grid>
        </Grid>
    </Border>
</Window>




