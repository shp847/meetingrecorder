<Window x:Class="MeetingRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:branding="clr-namespace:MeetingRecorder.Core.Branding;assembly=MeetingRecorder.Core"
        Title="{x:Static branding:AppBranding.DisplayNameWithVersion}"
        Icon="Assets/MeetingRecorder.ico"
        Height="840"
        Width="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DashboardStartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#204B46" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#204B46" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#DCE1DA" />
                    <Setter Property="Foreground" Value="#7A847E" />
                    <Setter Property="BorderBrush" Value="#C7CCC6" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DashboardStopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#B04A3A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#B04A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#DCE1DA" />
                    <Setter Property="Foreground" Value="#7A847E" />
                    <Setter Property="BorderBrush" Value="#C7CCC6" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border Background="#F4F2EA" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="ProductHeadingTextBlock"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#16211F"
                           Text="{x:Static branding:AppBranding.DisplayNameWithVersion}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#45504D"
                           TextWrapping="Wrap"
                           Text="Local-first meeting recording for Teams, Google Meet, Zoom, Webex, and other conferencing apps. Assisted auto-detection currently focuses on Teams and Google Meet." />
            </StackPanel>

            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Margin="0,20,0,0"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem x:Name="DashboardTabItem" Header="Dashboard">
                    <ScrollViewer Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="16"
                                CornerRadius="12"
                                Background="#E6ECE6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#16211F"
                                           Text="Status" />
                                <TextBlock x:Name="StatusTextBlock"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="DetectionTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap" />
                                <Border x:Name="ModelHealthBanner"
                                        Margin="0,12,0,0"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="#F7D9D4"
                                        BorderBrush="#B04A3A"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="ModelHealthBannerTextBlock"
                                               Foreground="#8E2B1B"
                                               TextWrapping="Wrap" />
                                </Border>
                                <Border x:Name="UpdateBanner"
                                        Margin="0,12,0,0"
                                        Padding="12"
                                        CornerRadius="10"
                                        Background="#E4F1EA"
                                        BorderBrush="#3F7A67"
                                        BorderThickness="1"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="UpdateBannerTextBlock"
                                                   Foreground="#214B3F"
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button x:Name="DashboardOpenUpdatesButton"
                                                    Width="150"
                                                    Height="30"
                                                    Click="OpenUpdatesTabButton_OnClick"
                                                    Content="Open Updates Tab" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1"
                                    Margin="0,20,0,0">
                            <Border Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Readiness" />
                                    <TextBlock x:Name="DashboardRecordingReadinessTextBlock"
                                               Margin="0,10,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="DashboardModelReadinessTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="DashboardDiarizationReadinessTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="DashboardUpdatesReadinessTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Manual update checks and installs live on the Updates tab so the Dashboard can stay focused on recording." />
                                    <Border Margin="0,14,0,0"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="#F7F7F4">
                                        <StackPanel>
                                            <TextBlock x:Name="DashboardPrimaryActionHeadlineTextBlock"
                                                       FontWeight="SemiBold"
                                                       Foreground="#16211F"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="DashboardPrimaryActionBodyTextBlock"
                                                       Margin="0,6,0,0"
                                                       Foreground="#45504D"
                                                       TextWrapping="Wrap" />
                                            <Button x:Name="DashboardPrimaryActionButton"
                                                    Width="150"
                                                    Height="32"
                                                    Margin="0,12,0,0"
                                                    HorizontalAlignment="Left"
                                                    Click="DashboardPrimaryActionButton_OnClick"
                                                    Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,20,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="StartButton"
                                        Style="{StaticResource DashboardStartButtonStyle}"
                                        Width="160"
                                        Height="42"
                                        Margin="0,0,12,0"
                                        Click="StartButton_OnClick"
                                        Content="Start Recording" />
                                <Button x:Name="StopButton"
                                        Style="{StaticResource DashboardStopButtonStyle}"
                                        Width="160"
                                        Height="42"
                                        Click="StopButton_OnClick"
                                        Content="Stop Recording" />
                            </StackPanel>
                            <TextBlock x:Name="RecordingControlsHintTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#45504D"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="3"
                                Margin="0,20,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Live Audio Capture" />
                                <TextBlock x:Name="AudioCaptureGraphStatusTextBlock"
                                           Margin="0,8,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap"
                                           Text="Start a recording to see live capture activity." />
                                <Border Margin="0,12,0,0"
                                        Height="96"
                                        CornerRadius="10"
                                        Background="#F7F7F4"
                                        BorderBrush="#D4D7D1"
                                        BorderThickness="1">
                                    <Canvas x:Name="AudioCaptureGraphCanvas"
                                            SizeChanged="AudioCaptureGraphCanvas_OnSizeChanged">
                                        <Polyline x:Name="AudioCaptureGraphPolyline"
                                                  Stroke="#204B46"
                                                  StrokeThickness="2"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Margin="0,20,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Current Meeting Title" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap"
                                           Text="Type a title while recording. The current text is applied automatically when recording stops and becomes the published filename stem." />
                                <TextBox x:Name="CurrentMeetingTitleTextBox"
                                         Margin="0,10,0,0"
                                         Height="34"
                                         VerticalContentAlignment="Center"
                                         TextChanged="CurrentMeetingTitleTextBox_OnTextChanged" />
                                <TextBlock x:Name="CurrentMeetingTitleStatusTextBlock"
                                           Margin="0,10,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="5"
                                Margin="0,20,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Recent Activity" />
                                <TextBox x:Name="ActivityTextBox"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="MeetingsTabItem" Header="Meetings">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#45504D"
                                           Text="Published meetings from the current audio and transcript output folders." />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap">
                                    <Run Text="Shared folders: " />
                                    <Hyperlink Click="AudioFolderLink_OnClick">
                                        <Run Text="Open audio folder" />
                                    </Hyperlink>
                                    <Run Text=" | " />
                                    <Hyperlink Click="TranscriptFolderLink_OnClick">
                                        <Run Text="Open transcript folder" />
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <Button x:Name="RefreshMeetingsButton"
                                    DockPanel.Dock="Right"
                                    Width="120"
                                    Height="34"
                                    Click="RefreshMeetingsButton_OnClick"
                                    Content="Refresh List" />
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Padding="8"
                                Height="260"
                                CornerRadius="12"
                                Background="White">
                                <DataGrid x:Name="MeetingsDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Extended"
                                      SelectionChanged="MeetingsDataGrid_OnSelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title, Mode=OneWay}" Width="2*" />
                                    <DataGridTextColumn Header="Started (UTC)" Binding="{Binding StartedAtUtc, Mode=OneWay}" Width="1.3*" />
                                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration, Mode=OneWay}" Width="0.9*" />
                                    <DataGridTextColumn Header="Platform" Binding="{Binding Platform, Mode=OneWay}" Width="*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status, Mode=OneWay}" Width="*" />
                                    <DataGridTemplateColumn Header="Audio" Width="1.4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Hyperlink Click="AudioArtifactLink_OnClick">
                                                        <Run Text="{Binding AudioFileName, Mode=OneWay}" />
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Transcript" Width="1.4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Hyperlink Click="TranscriptArtifactLink_OnClick">
                                                        <Run Text="{Binding TranscriptFileName, Mode=OneWay}" />
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <ScrollViewer Grid.Row="2"
                                      Margin="0,16,0,0"
                                      VerticalScrollBarVisibility="Auto">
                        <Border Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <StackPanel>
                                <Border Padding="14"
                                        CornerRadius="10"
                                        Background="#F7F7F4">
                                    <Expander IsExpanded="True">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Rename Published Meeting" />
                                        </Expander.Header>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Foreground="#45504D"
                                                           TextWrapping="Wrap"
                                                           Text="Renames matching audio and transcript artifacts together so their stems stay aligned." />
                                                <TextBlock x:Name="SelectedMeetingStatusTextBlock"
                                                           Margin="0,8,0,0"
                                                           Foreground="#45504D"
                                                           TextWrapping="Wrap" />
                                                <TextBox x:Name="SelectedMeetingTitleTextBox"
                                                         Margin="0,10,12,0"
                                                         Height="34"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="SelectedMeetingTitleTextBox_OnTextChanged" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Margin="12,22,0,0"
                                                        VerticalAlignment="Top">
                                                <Button x:Name="RenameSelectedMeetingButton"
                                                        Width="150"
                                                        Height="34"
                                                        Click="RenameSelectedMeetingButton_OnClick"
                                                        Content="Rename Meeting" />
                                                <Button x:Name="RetrySelectedMeetingButton"
                                                        Width="150"
                                                        Height="34"
                                                        Margin="0,10,0,0"
                                                        Click="RetrySelectedMeetingButton_OnClick"
                                                        Content="Re-Generate Transcript" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="#F7F7F4">
                                    <Expander IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Split Selected Recording" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Foreground="#45504D"
                                                       TextWrapping="Wrap"
                                                       Text="Select one published meeting above, choose where to split it, and the app will queue two new part 1 / part 2 meetings. The original stays in place." />
                                            <TextBox x:Name="SplitSelectedMeetingPointTextBox"
                                                     Margin="0,12,0,0"
                                                     Height="34"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="SplitSelectedMeetingPointTextBox_OnTextChanged" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#45504D"
                                                       TextWrapping="Wrap"
                                                       Text="Drag the slider for a quick split point, or type an exact value like 02:30." />
                                            <Slider x:Name="SplitSelectedMeetingSlider"
                                                    Margin="0,12,0,0"
                                                    Minimum="1"
                                                    Maximum="2"
                                                    Value="1"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="SplitSelectedMeetingSlider_OnValueChanged" />
                                            <DockPanel Margin="0,6,0,0">
                                                <TextBlock x:Name="SplitSelectedMeetingSliderMinTextBlock"
                                                           Foreground="#45504D"
                                                           Text="00:01" />
                                                <TextBlock x:Name="SplitSelectedMeetingSliderMaxTextBlock"
                                                           DockPanel.Dock="Right"
                                                           Foreground="#45504D"
                                                           Text="00:02" />
                                            </DockPanel>
                                            <TextBlock x:Name="SplitSelectedMeetingPreviewTextBlock"
                                                       Margin="0,8,0,0"
                                                       Foreground="#45504D"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Text="Part-length preview will appear here once a valid meeting is selected." />
                                            <WrapPanel Margin="0,12,0,0">
                                                <Button x:Name="SplitSelectedMeetingButton"
                                                        Width="160"
                                                        Height="34"
                                                        Click="SplitSelectedMeetingButton_OnClick"
                                                        Content="Split Into Two" />
                                            </WrapPanel>
                                            <TextBlock x:Name="SplitSelectedMeetingStatusTextBlock"
                                                       Margin="0,10,0,0"
                                                       Foreground="#45504D"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="#F7F7F4">
                                    <Expander IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Merge Selected Recordings" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Foreground="#45504D"
                                                       TextWrapping="Wrap"
                                                       Text="Select two or more published meetings above to combine them into one new queued recording. The originals stay in place." />
                                            <TextBox x:Name="MergeSelectedMeetingsTitleTextBox"
                                                     Margin="0,12,0,0"
                                                     Height="34"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="MergeSelectedMeetingsTitleTextBox_OnTextChanged" />
                                            <WrapPanel Margin="0,12,0,0">
                                                <Button x:Name="MergeSelectedMeetingsButton"
                                                        Width="180"
                                                        Height="34"
                                                        Click="MergeSelectedMeetingsButton_OnClick"
                                                        Content="Merge Selected Meetings" />
                                            </WrapPanel>
                                            <TextBlock x:Name="MergeSelectedMeetingsStatusTextBlock"
                                                       Margin="0,10,0,0"
                                                       Foreground="#45504D"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Expander>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="#F7F7F4">
                                    <Expander IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock FontWeight="SemiBold" Text="Diarized Speaker Names" />
                                        </Expander.Header>
                                        <StackPanel Margin="0,12,0,0">
                                            <TextBlock Foreground="#45504D"
                                                       TextWrapping="Wrap"
                                                       Text="If the transcript already has labels like Speaker 1 or Speaker 2, update them here and apply the changes across the selected meeting's transcript files." />
                                            <DataGrid x:Name="SpeakerLabelsEditorDataGrid"
                                                      Margin="0,12,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      HeadersVisibility="Column"
                                                      RowHeaderWidth="0"
                                                      Height="160">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Current Label"
                                                                        Binding="{Binding OriginalLabel, Mode=OneWay}"
                                                                        IsReadOnly="True"
                                                                        Width="*" />
                                                    <DataGridTemplateColumn Header="Display Name"
                                                                            Width="1.3*">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBox Height="28"
                                                                         VerticalContentAlignment="Center"
                                                                         Text="{Binding EditedLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <WrapPanel Margin="0,12,0,0">
                                                <Button x:Name="ApplySpeakerNamesButton"
                                                        Width="170"
                                                        Height="34"
                                                        Click="ApplySpeakerNamesButton_OnClick"
                                                        Content="Apply Speaker Names" />
                                            </WrapPanel>
                                            <TextBlock x:Name="SpeakerNamesStatusTextBlock"
                                                       Margin="0,10,0,0"
                                                       Foreground="#45504D"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Expander>
                                </Border>
                            </StackPanel>
                        </Border>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ModelsTabItem" Header="Models">
                    <ScrollViewer Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Whisper Model Setup" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="The transcription worker needs a valid local ggml Whisper model file. App releases no longer bundle large model binaries, so choose a downloadable model from the current GitHub release or import your own file into the managed model folder." />
                                    <TextBlock Margin="0,12,0,0"
                                               TextWrapping="Wrap">
                                        <Run Text="Configured model path: " />
                                        <Hyperlink Click="ModelPathLink_OnClick">
                                            <Run x:Name="ModelPathRun" />
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock x:Name="WhisperModelStatusTextBlock"
                                               Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="WhisperModelDetailsTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <ProgressBar x:Name="ModelOperationProgressBar"
                                                 Margin="0,12,0,0"
                                                 Height="6"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 IsIndeterminate="True"
                                                 Visibility="Collapsed" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Downloadable Models From GitHub" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Use the current release assets to choose which model you want on this machine. This keeps app installs and updates lighter because models are downloaded separately only when needed. The current release offers four English q8_0 options: tiny, base, small, and medium." />
                                    <ComboBox x:Name="AvailableRemoteModelsComboBox"
                                              Margin="0,12,0,0"
                                              DisplayMemberPath="DisplayText"
                                              SelectionChanged="AvailableRemoteModelsComboBox_OnSelectionChanged" />
                                    <TextBlock x:Name="SelectedRemoteModelSummaryTextBlock"
                                               Margin="0,10,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button x:Name="RefreshRemoteModelsButton"
                                                Width="180"
                                                Height="34"
                                                Margin="0,0,12,12"
                                                Click="RefreshRemoteModelsButton_OnClick"
                                                Content="Refresh GitHub Models" />
                                        <Button x:Name="DownloadSelectedRemoteModelButton"
                                                Width="190"
                                                Height="34"
                                                Margin="0,0,0,12"
                                                Click="DownloadSelectedRemoteModelButton_OnClick"
                                                Content="Download Selected Model" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Available Local Models" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Choose which shipped or imported model should be active for transcription. Imported models are copied into the managed model folder and remain available here." />
                                    <ComboBox x:Name="AvailableModelsComboBox"
                                              Margin="0,12,0,0"
                                              DisplayMemberPath="DisplayText"
                                              SelectionChanged="AvailableModelsComboBox_OnSelectionChanged" />
                                    <TextBlock x:Name="SelectedModelSummaryTextBlock"
                                               Margin="0,10,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap" />
