<Window x:Class="MeetingRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:branding="clr-namespace:MeetingRecorder.Core.Branding;assembly=MeetingRecorder.Core"
        Title="{x:Static branding:AppBranding.DisplayNameWithVersion}"
        Icon="Assets/MeetingRecorder.ico"
        Height="920"
        Width="1440"
        MinHeight="860"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="DashboardStartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
                    <Setter Property="Foreground" Value="#7A847E" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DashboardStopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppCanvasBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrongOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
                    <Setter Property="Foreground" Value="#7A847E" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MeetingsToolSectionBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ConfigSectionBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ConfigHelpTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontFamily" Value="{StaticResource AppUiFontFamily}" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ShellSurfaceCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="HomeSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppUiFontFamily}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
        </Style>
        <Style x:Key="MutedHelperTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppUiFontFamily}" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="StatusChipBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="InlineRecommendationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#0B57D0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#073C9C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Content" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="InlineArtifactActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#0B57D0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#073C9C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7A847E" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource AppCanvasBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrongOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppAccentBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppCardBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppMutedCardBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7A847E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HomeReadinessRowBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="HomeReadinessActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="124" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppCardBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppMutedCardBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7A847E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TertiaryLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource AppLinkBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#073C9C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7A847E" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HostedSurfaceBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="560" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Panel.ZIndex" Value="20" />
        </Style>
        <Style x:Key="TechnicalMetaLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="QuickSettingToggleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Width" Value="72" />
            <Setter Property="MinWidth" Value="68" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource AppCanvasBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrongOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppAccentBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppCardBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Active" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AppAccentBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#7A847E" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource AppCanvasBrush}" Padding="16">
        <Grid Background="{StaticResource AppCanvasPatternBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="4,4,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ProductHeadingTextBlock"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource AppUiFontFamily}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextBrush}"
                           Text="MEETING RECORDER" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border x:Name="HeaderShellStatusBorder"
                            MinWidth="390"
                            MinHeight="44"
                            Padding="10,6"
                            Margin="0,0,10,0"
                            Background="{StaticResource AppCardBrush}"
                            BorderBrush="{StaticResource AppOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse x:Name="HeaderShellStatusDot"
                                         Width="8"
                                         Height="8"
                                         Margin="0,0,8,0"
                                         Fill="{StaticResource AppSignalBrush}" />
                                <TextBlock x:Name="HeaderShellStatusLabelTextBlock"
                                           VerticalAlignment="Center"
                                           FontFamily="{StaticResource AppMonoFontFamily}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextBrush}"
                                           Text="READY" />
                            </StackPanel>

                            <TextBlock x:Name="HeaderShellStatusDetailTextBlock"
                                       Grid.Column="1"
                                       Width="180"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource AppMonoFontFamily}"
                                       FontSize="11"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       Text="Manual or auto-detect"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />

                            <Button x:Name="HeaderShellStatusActionButton"
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ShellStatusActionButtonStyle}"
                                    Click="HeaderShellStatusActionButton_OnClick"
                                    Visibility="Collapsed" />
                            </Grid>
                    </Border>

                    <Border x:Name="HeaderQueueStatusBorder"
                            MinWidth="176"
                            MinHeight="44"
                            Padding="10,6"
                            Margin="0,0,10,0"
                            Background="{StaticResource AppCardBrush}"
                            BorderBrush="{StaticResource AppOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderQueueStatusLabelTextBlock"
                                       FontFamily="{StaticResource AppMonoFontFamily}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextBrush}"
                                       Text="QUEUED 0" />
                            <TextBlock x:Name="HeaderQueueStatusDetailTextBlock"
                                       Margin="0,2,0,0"
                                       FontFamily="{StaticResource AppMonoFontFamily}"
                                       FontSize="11"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       Text="Approximate processing status"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="HeaderSettingsButton"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Margin="0"
                            Click="HeaderSettingsButton_OnClick"
                            Content="Settings" />
                    <Button x:Name="HeaderHelpButton"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Click="HeaderHelpButton_OnClick"
                            Content="Help" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,10,0,0">
                <TabControl x:Name="MainTabControl"
                            SelectedIndex="0"
                            Style="{StaticResource ShellSegmentedTabControlStyle}"
                            ItemContainerStyle="{StaticResource ShellSegmentedTabItemStyle}"
                            SelectionChanged="MainTabControl_OnSelectionChanged">
                <TabItem x:Name="DashboardTabItem" Header="Home">
                        <ScrollViewer x:Name="HomeDashboardScrollViewer"
                                      Margin="0,12,0,0"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="HomeDashboardGrid"
                              MinWidth="1040"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border x:Name="HomeRecordingConsoleBorder"
                                    MinWidth="1040"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource ShellSurfaceCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource TechnicalMetaLabelStyle}"
                                                   Text="SESSION TITLE (REQUIRED)" />
                                        <TextBox x:Name="CurrentMeetingTitleTextBox"
                                                 Margin="0,10,0,0"
                                                 Height="52"
                                                 AcceptsReturn="False"
                                                 FontSize="22"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="NoWrap"
                                                 VerticalContentAlignment="Center"
                                                 TextChanged="CurrentMeetingTitleTextBox_OnTextChanged" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Style="{StaticResource TechnicalMetaLabelStyle}"
                                                           Text="CLIENT / PROJECT (OPTIONAL)" />
                                                <TextBox x:Name="CurrentMeetingProjectTextBox"
                                                         Margin="0,8,0,0"
                                                         Height="40"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="CurrentMeetingProjectTextBox_OnTextChanged" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Style="{StaticResource TechnicalMetaLabelStyle}"
                                                           Text="KEY ATTENDEES (OPTIONAL)" />
                                                <TextBox x:Name="CurrentMeetingKeyAttendeesTextBox"
                                                         Margin="0,8,0,0"
                                                         Height="40"
                                                         ToolTip="Use commas or semicolons to separate attendees."
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="CurrentMeetingKeyAttendeesTextBox_OnTextChanged" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="CurrentMeetingTitleStatusTextBlock"
                                                   Margin="0,10,0,0"
                                                   Style="{StaticResource TechnicalMetaLabelStyle}" />
                                        <Grid x:Name="CurrentRecordingElapsedGrid"
                                              Margin="0,8,0,0"
                                              Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Style="{StaticResource TechnicalMetaLabelStyle}"
                                                       Text="RECORDING TIME" />
                                            <TextBlock x:Name="CurrentRecordingElapsedTextBlock"
                                                       Grid.Column="2"
                                                       Style="{StaticResource TechnicalMetaLabelStyle}" />
                                        </Grid>
                                        <TextBlock x:Name="CurrentDetectedAudioSourceTextBlock"
                                                   Margin="0,8,0,0"
                                                   Foreground="#45504D"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Row="1"
                                            Margin="0,18,0,0"
                                            Padding="16"
                                            Height="220"
                                            CornerRadius="4"
                                            Background="{StaticResource AppMutedCardBrush}"
                                            BorderBrush="{StaticResource AppOutlineBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="AudioCaptureGraphStatusTextBlock"
                                                       Style="{StaticResource TechnicalMetaLabelStyle}"
                                                       Text="Live audio graph. Current peak: 0.000." />

                                            <Canvas x:Name="AudioCaptureGraphCanvas"
                                                    Grid.Row="1"
                                                    Margin="0,16,0,0"
                                                    SizeChanged="AudioCaptureGraphCanvas_OnSizeChanged">
                                                <Polyline x:Name="AudioCaptureGraphPolyline"
                                                          Stroke="{StaticResource AppSignalBrush}"
                                                          StrokeThickness="2"
                                                          StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2"
                                          Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                            <Button x:Name="HomePrimaryActionButton"
                                                    Style="{StaticResource DashboardStartButtonStyle}"
                                                    Grid.Column="0"
                                                    Height="52"
                                                    Click="StartButton_OnClick"
                                                    Content="START" />
                                            <Button x:Name="StopButton"
                                                    Style="{StaticResource DashboardStopButtonStyle}"
                                                    Grid.Column="2"
                                                    Height="52"
                                                    Click="StopButton_OnClick"
                                                    Content="STOP" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid x:Name="HomeQuickSettingsGrid"
                                  Grid.Row="1"
                                  Margin="0,12,0,0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="HomeMicCaptureQuickSettingBorder"
                                        Style="{StaticResource ShellSurfaceCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Style="{StaticResource TechnicalMetaLabelStyle}"
                                                       Text="MICROPHONE CAPTURE" />
                                            <TextBlock x:Name="HomeMicCaptureQuickSettingSummaryTextBlock"
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource MutedHelperTextStyle}" />
                                        </StackPanel>

                                        <Grid x:Name="HomeMicCaptureToggleGrid"
                                              Grid.Row="1"
                                              Margin="0,14,0,0"
                                              HorizontalAlignment="Left">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
