<Window x:Class="MeetingRecorder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Recorder"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterScreen">
    <Border Background="#F4F2EA" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#16211F"
                           Text="Meeting Recorder" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#45504D"
                           TextWrapping="Wrap"
                           Text="Local-first recording for Teams and Google Meet with durable session files and Power Automate-ready transcript publishing." />
            </StackPanel>

            <TabControl Grid.Row="1"
                        Margin="0,20,0,0"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Dashboard">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="16"
                                CornerRadius="12"
                                Background="#E6ECE6">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="#16211F"
                                           Text="Status" />
                                <TextBlock x:Name="StatusTextBlock"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="DetectionTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1"
                                    Margin="0,20,0,0"
                                    Orientation="Horizontal">
                            <Button x:Name="StartButton"
                                    Width="160"
                                    Height="42"
                                    Margin="0,0,12,0"
                                    Background="#204B46"
                                    Foreground="White"
                                    Click="StartButton_OnClick"
                                    Content="Start Recording" />
                            <Button x:Name="StopButton"
                                    Width="160"
                                    Height="42"
                                    Background="#B04A3A"
                                    Foreground="White"
                                    Click="StopButton_OnClick"
                                    Content="Stop Recording" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                Margin="0,20,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Rename Current Recording" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Update the in-progress meeting title before the final audio and transcript files are published." />
                                    <TextBox x:Name="CurrentMeetingTitleTextBox"
                                             Margin="0,10,12,0"
                                             Height="34"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                                <Button x:Name="RenameCurrentButton"
                                        Grid.Column="1"
                                        Width="140"
                                        Height="34"
                                        Margin="12,28,0,0"
                                        VerticalAlignment="Top"
                                        Click="RenameCurrentButton_OnClick"
                                        Content="Rename Current" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Outputs" />
                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                                        <Run Text="Audio folder: " />
                                        <Hyperlink Click="AudioFolderLink_OnClick">
                                            <Run x:Name="AudioPathRun" />
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                                        <Run Text="Transcript folder: " />
                                        <Hyperlink Click="TranscriptFolderLink_OnClick">
                                            <Run x:Name="TranscriptPathRun" />
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Configuration" />
                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                                        <Run Text="Config file: " />
                                        <Hyperlink Click="ConfigPathLink_OnClick">
                                            <Run x:Name="ConfigPathRun" />
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock x:Name="AutoDetectTextBlock"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4"
                                Margin="0,20,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Recent Activity" />
                                <TextBox x:Name="ActivityTextBox"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Meetings">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#45504D"
                                       Text="Published meetings from the current audio and transcript output folders." />
                            <Button x:Name="RefreshMeetingsButton"
                                    DockPanel.Dock="Right"
                                    Width="120"
                                    Height="34"
                                    Click="RefreshMeetingsButton_OnClick"
                                    Content="Refresh List" />
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Padding="8"
                                CornerRadius="12"
                                Background="White">
                            <DataGrid x:Name="MeetingsDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="MeetingsDataGrid_OnSelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                                    <DataGridTextColumn Header="Started (UTC)" Binding="{Binding StartedAtUtc}" Width="1.3*" />
                                    <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="*" />
                                    <DataGridTextColumn Header="Audio" Binding="{Binding AudioFileName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Transcript" Binding="{Binding TranscriptFileName}" Width="1.5*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,16,0,0"
                                Padding="16"
                                CornerRadius="12"
                                Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontWeight="SemiBold" Text="Rename Published Meeting" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#45504D"
                                               TextWrapping="Wrap"
                                               Text="Renames matching audio and transcript artifacts together so their stems stay aligned." />
                                    <TextBox x:Name="SelectedMeetingTitleTextBox"
                                             Margin="0,10,12,0"
                                             Height="34"
                                             VerticalContentAlignment="Center" />
                                </StackPanel>
                                <Button x:Name="RenameSelectedMeetingButton"
                                        Grid.Column="1"
                                        Width="150"
                                        Height="34"
                                        Margin="12,28,0,0"
                                        VerticalAlignment="Top"
                                        Click="RenameSelectedMeetingButton_OnClick"
                                        Content="Rename Meeting" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Config">
                    <ScrollViewer Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="16"
                                    CornerRadius="12"
                                    Background="White">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" FontWeight="SemiBold" Text="Configuration Editor" />
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Margin="0,6,0,16" Foreground="#45504D" TextWrapping="Wrap" Text="Changes are saved and hot-reloaded into the running app. Some settings only affect the next recording or the next processing run." />

                                    <TextBlock Grid.Row="2" Margin="0,0,12,12" VerticalAlignment="Center" Text="Audio output folder" />
                                    <TextBox x:Name="ConfigAudioOutputDirTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately" />

                                    <TextBlock Grid.Row="3" Margin="0,0,12,12" VerticalAlignment="Center" Text="Transcript output folder" />
                                    <TextBox x:Name="ConfigTranscriptOutputDirTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately" />

                                    <TextBlock Grid.Row="4" Margin="0,0,12,12" VerticalAlignment="Center" Text="Work folder" />
                                    <TextBox x:Name="ConfigWorkDirTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Next recording only" />

                                    <TextBlock Grid.Row="5" Margin="0,0,12,12" VerticalAlignment="Center" Text="Model cache folder" />
                                    <TextBox x:Name="ConfigModelCacheDirTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="5" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Next processing run" />

                                    <TextBlock Grid.Row="6" Margin="0,0,12,12" VerticalAlignment="Center" Text="Whisper model path" />
                                    <TextBox x:Name="ConfigTranscriptionModelPathTextBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="6" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Next processing run" />

                                    <TextBlock Grid.Row="7" Margin="0,0,12,12" VerticalAlignment="Center" Text="Diarization asset path" />
                                    <TextBox x:Name="ConfigDiarizationAssetPathTextBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="7" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Next processing run" />

                                    <TextBlock Grid.Row="8" Margin="0,0,12,12" VerticalAlignment="Center" Text="Auto-detect audio threshold" />
                                    <TextBox x:Name="ConfigAutoDetectThresholdTextBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="8" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately" />

                                    <TextBlock Grid.Row="9" Margin="0,0,12,12" VerticalAlignment="Center" Text="Meeting stop timeout (sec)" />
                                    <TextBox x:Name="ConfigMeetingStopTimeoutTextBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,12" Height="32" VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Row="9" Grid.Column="2" Margin="12,0,0,12" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately" />

                                    <StackPanel Grid.Row="10" Grid.ColumnSpan="3" Orientation="Horizontal">
                                        <CheckBox x:Name="ConfigMicCaptureCheckBox" Margin="0,8,18,0" Content="Enable microphone capture" />
                                        <TextBlock Margin="0,10,18,0" VerticalAlignment="Center" Foreground="#45504D" Text="Next recording only" />
                                        <CheckBox x:Name="ConfigAutoDetectCheckBox" Margin="0,8,0,0" Content="Enable auto-detection" />
                                        <TextBlock Margin="12,10,0,0" VerticalAlignment="Center" Foreground="#45504D" Text="Applies immediately" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Margin="0,16,0,0"
                                        Orientation="Horizontal">
                                <Button x:Name="SaveConfigButton"
                                        Width="140"
                                        Height="34"
                                        Click="SaveConfigButton_OnClick"
                                        Content="Save Config" />
                                <TextBlock x:Name="ConfigSaveStatusTextBlock"
                                           Margin="16,8,0,0"
                                           Foreground="#45504D"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
