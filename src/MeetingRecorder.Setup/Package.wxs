<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Meeting Recorder"
    Manufacturer="Meeting Recorder"
    Version="$(var.ProductVersion)"
    UpgradeCode="F0C6921D-2F56-4BB2-96A1-62FCB7E4C936"
    Language="1033"
    Scope="perUser"
    InstallerVersion="500"
    Compressed="yes">

    <SummaryInformation Description="Meeting Recorder" Manufacturer="Meeting Recorder" />
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of Meeting Recorder is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="ProductIcon" SourceFile="..\MeetingRecorder.App\Assets\MeetingRecorder.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="ARPINSTALLLOCATION" Secure="yes" />
    <Property Id="MsiLogging" Value="voicewarmup!" />
    <Property Id="MODEL_OPTION_TRANSCRIPTION" Value="standard" Secure="yes" />
    <Property Id="MODEL_OPTION_SPEAKER_LABELING" Value="standard" Secure="yes" />
    <Property Id="PHYSICALUSERPROFILE" Secure="yes">
      <RegistrySearch
        Id="SearchPhysicalUserProfile"
        Root="HKCU"
        Key="Volatile Environment"
        Name="USERPROFILE"
        Type="raw" />
    </Property>
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="Meeting Recorder installed successfully. Setup tried the selected model downloads. If transcription still needs setup, open Settings > Setup at first launch to finish the download or import an approved model." />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Meeting Recorder" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <SetProperty Id="INSTALLFOLDER" Value="[PHYSICALUSERPROFILE]\Documents\MeetingRecorder" After="AppSearch" Sequence="both" Condition="PHYSICALUSERPROFILE" />
    <SetProperty Id="ARPINSTALLLOCATION" Value="[INSTALLFOLDER]" After="CostFinalize" Sequence="execute" />
    <SetProperty Id="WixShellExecTarget" Value="[INSTALLFOLDER]Launch-MeetingRecorder-AfterInstall.vbs" After="CostFinalize" Sequence="ui" />
    <SetProperty
      Id="WixQuietExecCmdLine"
      Value="&quot;[INSTALLFOLDER]AppPlatform.Deployment.Cli.exe&quot; provision-models -i &quot;[INSTALLFOLDER].&quot; -m &quot;[INSTALLFOLDER]MeetingRecorder.product.json&quot; -t [MODEL_OPTION_TRANSCRIPTION] -s [MODEL_OPTION_SPEAKER_LABELING] -l &quot;[LocalAppDataFolder]MeetingRecorder\m.log&quot;"
      After="InstallFiles"
      Sequence="execute"
      Condition="NOT Installed AND NOT REMOVE~=&quot;ALL&quot;" />

    <CustomAction
      Id="LaunchApplication"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixShellExec"
      Impersonate="yes"
      Return="ignore" />
    <CustomAction
      Id="ProvisionModelsCustomAction"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec"
      Execute="immediate"
      Return="check" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <UI>
      <Dialog Id="ModelOptionsDlg" Width="370" Height="320" Title="[ProductName] Setup" NoMinimize="yes">
        <Control Id="Title" Type="Text" X="15" Y="8" Width="330" Height="18" Transparent="yes" NoPrefix="yes" Text="Choose setup options" />
        <Control Id="Description" Type="Text" X="20" Y="28" Width="330" Height="22" Transparent="yes" NoPrefix="yes" Text="Recommended setup tries the Standard transcription download now. Recommended setup also tries the Standard speaker-labeling download now." />
        <Control Id="AdvancedText" Type="Text" X="20" Y="50" Width="330" Height="22" Transparent="yes" NoPrefix="yes" Text="Advanced options let you try the larger Higher Accuracy downloads, or skip speaker labeling for now." />
        <Control Id="TradeoffText" Type="Text" X="20" Y="72" Width="330" Height="36" Transparent="yes" NoPrefix="yes" Text="Tradeoff: Higher Accuracy can improve transcript or speaker-label quality, but it uses a larger download and may lead to slower processing. If a download is blocked, install still finishes and setup can continue at first launch." />
        <Control Id="TranscriptionLabel" Type="Text" X="20" Y="116" Width="330" Height="12" Transparent="yes" NoPrefix="yes" Text="Transcription" />
        <Control Id="TranscriptionOptions" Type="RadioButtonGroup" X="20" Y="130" Width="330" Height="36" Property="MODEL_OPTION_TRANSCRIPTION">
          <RadioButtonGroup Property="MODEL_OPTION_TRANSCRIPTION">
            <RadioButton X="0" Y="0" Width="320" Height="16" Text="Recommended: Standard download" Value="standard" />
            <RadioButton X="0" Y="18" Width="320" Height="16" Text="Advanced: Higher Accuracy download" Value="highAccuracy" />
          </RadioButtonGroup>
        </Control>
        <Control Id="SpeakerLabelingLabel" Type="Text" X="20" Y="176" Width="330" Height="12" Transparent="yes" NoPrefix="yes" Text="Speaker labeling" />
        <Control Id="SpeakerLabelingOptions" Type="RadioButtonGroup" X="20" Y="190" Width="330" Height="54" Property="MODEL_OPTION_SPEAKER_LABELING">
          <RadioButtonGroup Property="MODEL_OPTION_SPEAKER_LABELING">
            <RadioButton X="0" Y="0" Width="320" Height="16" Text="Recommended: Standard download" Value="standard" />
            <RadioButton X="0" Y="18" Width="320" Height="16" Text="Advanced: Higher Accuracy download" Value="highAccuracy" />
            <RadioButton X="0" Y="36" Width="320" Height="16" Text="Advanced: Skip speaker labeling for now" Value="disabled" />
          </RadioButtonGroup>
        </Control>
        <Control Id="HelpText" Type="Text" X="20" Y="252" Width="330" Height="34" Transparent="yes" NoPrefix="yes" Text="Recording stays blocked until transcription is ready. Speaker labeling stays optional and can be added later from Settings > Setup." />
        <Control Id="BottomLine" Type="Line" X="0" Y="288" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="166" Y="297" Width="62" Height="17" Text="Back">
          <Publish Event="NewDialog" Value="WelcomeDlg" Condition="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="232" Y="297" Width="62" Height="17" Default="yes" Text="Next">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="298" Y="297" Width="62" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" Condition="1" />
        </Control>
      </Dialog>

      <Publish
        Dialog="WelcomeDlg"
        Control="Next"
        Event="NewDialog"
        Value="ModelOptionsDlg"
        Order="999"
        Condition="NOT Installed" />
      <Publish
        Dialog="WelcomeDlg"
        Control="Next"
        Event="NewDialog"
        Value="VerifyReadyDlg"
        Order="1000"
        Condition="Installed" />
      <Publish
        Dialog="VerifyReadyDlg"
        Control="Back"
        Event="NewDialog"
        Value="ModelOptionsDlg"
        Order="999"
        Condition="NOT Installed" />
      <Publish
        Dialog="VerifyReadyDlg"
        Control="Back"
        Event="NewDialog"
        Value="WelcomeDlg"
        Order="1000"
        Condition="Installed" />
      <Publish
        Dialog="ExitDialog"
        Control="Finish"
        Event="DoAction"
        Value="LaunchApplication"
        Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <InstallExecuteSequence>
      <Custom Action="ProvisionModelsCustomAction" After="InstallFiles" Condition="NOT Installed AND NOT REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <StandardDirectory Id="TARGETDIR">
      <Directory Id="INSTALLFOLDER" Name="MeetingRecorder" />
    </StandardDirectory>

<?if $(var.HasHarvestedAppFiles) = true ?>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Meeting Recorder" />
    </StandardDirectory>
<?endif ?>

    <Feature Id="MainFeature" Title="Meeting Recorder" Level="1" AllowAdvertise="no">
      <ComponentGroupRef Id="$(var.AppFilesComponentGroupId)" />
      <ComponentRef Id="InstallFolderCleanupComponent" />
<?if $(var.HasHarvestedAppFiles) = true ?>
      <ComponentRef Id="StartMenuShortcutComponent" />
<?endif ?>
    </Feature>

    <Component Id="InstallFolderCleanupComponent" Directory="INSTALLFOLDER" Guid="2E95628E-D3E9-4429-B237-B0A28F6A37D2">
      <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Meeting Recorder" Name="InstallFolderCleanup" Type="integer" Value="1" KeyPath="yes" />
    </Component>

<?if $(var.HasHarvestedAppFiles) = true ?>
    <Component Id="StartMenuShortcutComponent" Directory="ApplicationProgramsFolder" Guid="A2129A35-BE1D-4F84-9F28-0D147755A4CD">
      <Shortcut
        Id="StartMenuMeetingRecorderShortcut"
        Name="Meeting Recorder"
        Description="Meeting Recorder"
        Target="[INSTALLFOLDER]MeetingRecorder.App.exe"
        WorkingDirectory="INSTALLFOLDER"
        Icon="ProductIcon"
        Advertise="no" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Meeting Recorder" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
<?endif ?>
  </Package>
</Wix>
