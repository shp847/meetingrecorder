<Window x:Class="AppPlatform.Shell.Wpf.HelpHostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help"
        Width="680"
        Height="720"
        MinWidth="620"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppCanvasBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/AppPlatform.Shell.Wpf;component/ShellTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppTextBrush}"
                       Text="Help" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource DialogBodyTextStyle}"
                       Text="Open release notes, bundled setup help, and the local data folders you usually need for troubleshooting." />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,18,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="About" />
                        <TextBlock x:Name="AboutDisplayNameTextBlock"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                        <TextBlock x:Name="AboutDescriptionTextBlock"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                        <TextBlock x:Name="AboutAuthorTextBlock"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="Support &amp; Troubleshooting" />
                        <TextBlock x:Name="SupportDescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                        <WrapPanel Margin="0,14,0,0">
                            <Button Margin="0,0,12,12"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="OpenSetupGuideButton_OnClick"
                                    Content="Open setup guide" />
                            <Button Margin="0,0,12,12"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="OpenLogsFolderButton_OnClick"
                                    Content="Open logs folder" />
                            <Button Margin="0,0,0,12"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="OpenDataFolderButton_OnClick"
                                    Content="Open data folder" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="RuntimeDiagnosticsBorder"
                        Margin="0,16,0,0"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="Runtime diagnostics" />
                        <TextBlock x:Name="RuntimeDiagnosticsTextBlock"
                                   Margin="0,10,0,0"
                                   FontFamily="Consolas"
                                   Style="{StaticResource DialogBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   xml:space="preserve" />
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="Version &amp; Release Notes" />
                        <TextBlock x:Name="ReleaseDescriptionTextBlock"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                        <Button Margin="0,14,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="OpenReleasePageButton_OnClick"
                                Content="Open release page" />
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="Legal notice" />
                        <TextBlock x:Name="LegalNoticeTextBlock"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FooterStatusTextBlock"
                       VerticalAlignment="Center"
                       Style="{StaticResource DialogBodyTextStyle}" />
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryActionButtonStyle}"
                    Click="CloseButton_OnClick"
                    Content="Close" />
        </Grid>
    </Grid>
</Window>
