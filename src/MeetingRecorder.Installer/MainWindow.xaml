<Window x:Class="MeetingRecorder.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Recorder Installer"
        Width="920"
        Height="760"
        MinWidth="820"
        MinHeight="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource AppCanvasBrush}">
    <Window.Resources>
        <Style x:Key="InstallerEyebrowTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="InstallerHeadlineTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="32" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InstallerLeadTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="InstallerInsetTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="MinHeight" Value="170" />
        </Style>

        <Style x:Key="InstallerProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InstallerToneBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppOutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Progress">
                    <Setter Property="Background" Value="{StaticResource AppMutedCardBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                    <Setter Property="Background" Value="{StaticResource AppSuccessBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppSuccessOutlineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Background" Value="{StaticResource AppWarningBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppWarningOutlineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Danger">
                    <Setter Property="Background" Value="{StaticResource AppDangerBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppDangerOutlineBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InstallerToneBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                    <Setter Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Foreground" Value="{StaticResource AppWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Danger">
                    <Setter Property="Foreground" Value="{StaticResource AppDangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InstallerStatusAccentStyle" TargetType="Border">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="CornerRadius" Value="18,0,0,18" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusTone}" Value="Success">
                    <Setter Property="Background" Value="{StaticResource AppSuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Warning">
                    <Setter Property="Background" Value="{StaticResource AppWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusTone}" Value="Danger">
                    <Setter Property="Background" Value="{StaticResource AppDangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InstallerPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="MinWidth" Value="172" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="InstallerSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryActionButtonStyle}">
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="InstallerGroupLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>
    </Window.Resources>

    <ScrollViewer x:Name="InstallerShellScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="InstallerHeroPanel"
                        Grid.Row="0">
                <TextBlock Style="{StaticResource InstallerEyebrowTextStyle}"
                           Text="EXECUTABLE INSTALLER" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource InstallerHeadlineTextStyle}"
                           Text="Meeting Recorder Installer" />
                <TextBlock Margin="0,12,0,0"
                           Style="{StaticResource InstallerLeadTextStyle}"
                           Text="This launcher prefers the colocated app package when one ships beside it and otherwise falls back to the shared GitHub command bootstrapper path. It then hands the install off to Documents\MeetingRecorder while writable runtime data such as config, logs, models, and work files stays separately under %LOCALAPPDATA%\MeetingRecorder." />
            </StackPanel>

            <Border x:Name="InstallerStatusCard"
                    Grid.Row="1"
                    Margin="0,24,0,0"
                    Padding="0"
                    Style="{StaticResource DialogCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource InstallerStatusAccentStyle}" />

                    <StackPanel Grid.Column="1"
                                Margin="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="InstallerToneBadge"
                                    Style="{StaticResource InstallerToneBadgeStyle}">
                                <TextBlock Style="{StaticResource InstallerToneBadgeTextStyle}"
                                           Text="{Binding StatusToneLabel}" />
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Margin="12,4,0,0"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource DialogBodyTextStyle}"
                                       Text="{Binding ReleaseSummary}" />
                        </Grid>

                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="{Binding StatusTitle}" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="15"
                                   Style="{StaticResource DialogBodyTextStyle}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="InstallerProgressCard"
                    Grid.Row="2"
                    Margin="0,18,0,0"
                    Style="{StaticResource DialogCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                               Text="Install progress" />
                    <ProgressBar Margin="0,14,0,0"
                                 Style="{StaticResource InstallerProgressBarStyle}"
                                 Value="{Binding ProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsIndeterminate}" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource DialogBodyTextStyle}"
                               Text="{Binding ProgressCaption}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="InstallerActivityCard"
                        Grid.Column="0"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="Installer activity" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}"
                                   Text="A running log of the install steps so it is easier to see what already happened." />
                        <TextBox Margin="0,14,0,0"
                                 Style="{StaticResource InstallerInsetTextBoxStyle}"
                                 Text="{Binding ActivityLog, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border x:Name="InstallerFallbackCard"
                        Grid.Column="2"
                        Style="{StaticResource DialogCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                                   Text="If the installer is blocked" />
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource DialogBodyTextStyle}"
                                   Text="You can fall back to the command installer or do a manual portable install. App files live in Documents\MeetingRecorder, while config, logs, models, and work files live under %LOCALAPPDATA%\MeetingRecorder. The steps below stay visible so the user is never stuck behind one blocked path." />
                        <TextBox Margin="0,14,0,0"
                                 Style="{StaticResource InstallerInsetTextBoxStyle}"
                                 Text="{Binding ManualSteps, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="InstallerActionsCard"
                    Grid.Row="4"
                    Margin="0,18,0,0"
                    Style="{StaticResource DialogCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogSectionTitleStyle}"
                               Text="Next steps" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource DialogBodyTextStyle}"
                               Text="Continue in the command window if the handoff succeeds, or use the fallback/manual steps below if the primary path is blocked." />

                    <TextBlock Margin="0,18,0,0"
                               Style="{StaticResource InstallerGroupLabelTextStyle}"
                               Text="Primary handoff paths" />
                    <WrapPanel x:Name="PrimaryActionsPanel"
                               Margin="0,12,0,0">
                        <Button Style="{StaticResource InstallerPrimaryButtonStyle}"
                                Click="RetryInstallButton_Click"
                                IsEnabled="{Binding CanRetryInstall}"
                                Content="Retry handoff" />
                        <Button Style="{StaticResource InstallerSecondaryButtonStyle}"
                                Click="BackupInstallerButton_Click"
                                IsEnabled="{Binding CanLaunchBackupInstaller}"
                                Content="Try backup CMD installer" />
                        <Button Style="{StaticResource InstallerSecondaryButtonStyle}"
                                Click="OpenInstallFolderButton_Click"
                                IsEnabled="{Binding CanOpenInstallFolder}"
                                Content="Open app folder" />
                    </WrapPanel>

                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource InstallerGroupLabelTextStyle}"
                               Text="Release and fallback tools" />
                    <WrapPanel x:Name="SecondaryActionsPanel"
                               Margin="0,12,0,0">
                        <Button Style="{StaticResource InstallerSecondaryButtonStyle}"
                                Click="OpenReleasePageButton_Click"
                                IsEnabled="{Binding CanOpenReleasePage}"
                                Content="Open release" />
                        <Button Style="{StaticResource InstallerSecondaryButtonStyle}"
                                Click="CopyManualStepsButton_Click"
                                IsEnabled="{Binding CanCopyManualSteps}"
                                Content="Copy manual steps" />
                        <Button Style="{StaticResource InstallerSecondaryButtonStyle}"
                                Click="CloseButton_Click"
                                Content="Close" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
